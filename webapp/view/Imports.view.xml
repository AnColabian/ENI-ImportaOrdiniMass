<mvc:View controllerName="importaordinivendita.controller.Imports"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page id="importsPage" showHeader="true" enableScrolling="false" busy="{history>/busy}">
        <customHeader>
            <Toolbar id="importsHeader" height="4rem">
                <Button id="importsBackButton" icon="sap-icon://nav-back" type="Transparent" press=".onNavBackToImport"/>
                <Title id="importsHeaderTitle" text="Tutte le importazioni (ordini di vendita)" level="H1" titleStyle="H4"/>
                <ToolbarSpacer id="importsHeaderSpacer"/>
                <Button id="importsBackToImportButton" text="Torna alla pagina importazione" type="Transparent" press=".onNavBackToImport"/>
            </Toolbar>
        </customHeader>
        <content>
            <VBox id="importsRoot" width="100%" class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiLargeMarginTop">
                <VBox id="importsFilterArea" class="sapUiSmallMarginBottom">
                    <HBox id="importsFilterRow" width="100%" alignItems="End" wrap="Wrap">
                        <VBox id="importsPeriodoBox" width="22rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                            <Label id="importsPeriodoLabel" text="Periodo importazione:"/>
                            <DateRangeSelection id="importsPeriodoPicker" width="100%" displayFormat="dd.MM.yyyy"/>
                        </VBox>
                        <VBox id="importsFileNameBox" width="22rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                            <Label id="importsFileNameLabel" text="Nome file:"/>
                            <MultiComboBox id="importsFileNameMultiCombo" width="100%" items="{history>/fileNameItems}">
                                <items>
                                    <core:Item key="{history>key}" text="{history>text}"/>
                                </items>
                            </MultiComboBox>
                        </VBox>
                        <VBox id="importsStatusBox" width="18rem" class="sapUiSmallMarginEnd sapUiSmallMarginBottom">
                            <Label id="importsStatusLabel" text="Stato di elaborazione:"/>
                            <ComboBox id="importsStatusComboBox" selectedKey="{history>/filters/status}" width="100%" items="{history>/statusItems}">
                                <items>
                                    <core:Item key="{history>key}" text="{history>text}"/>
                                </items>
                            </ComboBox>
                        </VBox>
                        <HBox id="importsFilterButtons" alignItems="End" class="sapUiSmallMarginBottom">
                            <Button id="importsStartButton" text="Avvio" type="Emphasized" press=".onHistorySearch" class="sapUiSmallMarginEnd"/>
                            <Button id="importsResetButton" text="Resetta" type="Transparent" press=".onHistoryReset"/>
                        </HBox>
                    </HBox>
                </VBox>
                <OverflowToolbar id="importsTableToolbar">
                    <Title id="importsTableTitle" text="{= 'Importazioni (' + ${history>/count} + ')' }" level="H2"/>
                    <ToolbarSpacer id="importsTableToolbarSpacer"/>
                </OverflowToolbar>
                <Table id="importsTable" width="100%" fixedLayout="false" growing="true" growingThreshold="50" items="{history>/visibleRows}">
                    <columns>
                        <Column id="importsColName" width="28rem">
                            <Text text="Nome file"/>
                        </Column>
                        <Column id="importsColStatus" width="16rem">
                            <Text text="Stato di elaborazione"/>
                        </Column>
                        <Column id="importsColDate" width="16rem">
                            <Text text="Data di importazione"/>
                        </Column>
                        <Column id="importsColAuthor" width="14rem">
                            <Text text="Autore importazione"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Navigation" highlight="{parts: [{path: 'history>Stato'}], formatter: '.formatter.statoHighlight'}" press=".onHistoryRowPress">
                            <cells>
                                <Text text="{history>FileName}"/>
                                <ObjectStatus text="{history>Stato}" state="{parts: [{path: 'history>Stato'}], formatter: '.formatter.statoState'}" icon="{parts: [{path: 'history>Stato'}], formatter: '.formatter.statoIcon'}"/>
                                <Text text="{history>DataOraDisplay}"/>
                                <Text text="{history>ImportAuthor}"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>