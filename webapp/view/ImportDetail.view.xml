<mvc:View controllerName="importaordinivendita.controller.ImportDetail"
    xmlns:mvc="sap.ui.core.mvc"
    xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Page id="importDetailPage" showHeader="true" enableScrolling="true">
        <customHeader>
            <Toolbar id="importDetailHeader" height="4rem">
                <Button id="importDetailBackButton" icon="sap-icon://nav-back" type="Transparent" press=".onNavBack"/>
                <Title id="importDetailHeaderTitle" text="{detail>/FileName}" level="H1" titleStyle="H4"/>
                <ToolbarSpacer id="importDetailHeaderSpacer"/>
                <Button id="importDetailBackToImportsButton" text="Tutte le importazioni (ordini di vendita)" type="Transparent" press=".onBackToImports"/>
            </Toolbar>
        </customHeader>
        <content>
            <VBox id="importDetailRoot" width="100%" class="sapUiSmallMarginBegin sapUiSmallMarginEnd sapUiLargeMarginTop">
                <HBox id="importDetailInfoBox" width="100%" wrap="Wrap" class="sapUiSmallMarginBottom">
                    <VBox id="importDetailInfoAuthor" class="sapUiMediumMarginEnd">
                        <Label text="Autore importazione:"/>
                        <Text text="{detail>/ImportAuthor}"/>
                    </VBox>
                    <VBox id="importDetailInfoDate" class="sapUiMediumMarginEnd">
                        <Label text="Data di importazione:"/>
                        <Text text="{detail>/DataOraDisplay}"/>
                    </VBox>
                    <VBox id="importDetailInfoTotale" class="sapUiMediumMarginEnd">
                        <Label text="Totale posizioni:"/>
                        <Text text="{detail>/Totale}"/>
                    </VBox>
                    <VBox id="importDetailInfoOk" class="sapUiMediumMarginEnd">
                        <Label text="Completate:"/>
                        <ObjectStatus text="{detail>/Ok}" state="Success"/>
                    </VBox>
                    <VBox id="importDetailInfoKo" class="sapUiMediumMarginEnd">
                        <Label text="Non riuscite:"/>
                        <ObjectStatus text="{detail>/Ko}" state="Error"/>
                    </VBox>
                    <VBox id="importDetailInfoStato">
                        <Label text="Stato di elaborazione:"/>
                        <ObjectStatus text="{detail>/Stato}" state="{detail>/StatoState}" icon="{parts: [{path: 'detail>/Stato'}], formatter: '.formatter.statoIcon'}"/>
                    </VBox>
                </HBox>
                <MessageStrip id="importDetailKoStrip" visible="{detail>/HasKo}" text="Correggi i record errati e importa nuovamente." type="Error" showIcon="true" class="sapUiSmallMarginBottom">
                    <link>
                        <Link id="importDetailRetryLink" text="Importa" press=".onRetryImport"/>
                    </link>
                </MessageStrip>
                <OverflowToolbar id="importDetailTableToolbar">
                    <Title id="importDetailTableTitle" text="{= 'Posizioni elaborazione (' + ${detail>/Count} + ')' }" level="H2"/>
                    <ToolbarSpacer id="importDetailTableToolbarSpacer"/>
                    <SearchField id="importDetailTableSearch" value="{detail>/Search}" width="26rem" placeholder="Cerca" search=".onDetailSearch"/>
                </OverflowToolbar>
                <Table id="importDetailTable" width="100%" fixedLayout="false" growing="true" growingThreshold="50" items="{detail>/VisibleRows}">
                    <columns>
                        <Column id="importDetailColIdOdvTmp" width="14rem">
                            <Text text="ID ODV temporaneo"/>
                        </Column>
                        <Column id="importDetailColPosnr" width="10rem">
                            <Text text="Posizione"/>
                        </Column>
                        <Column id="importDetailColStato" width="14rem">
                            <Text text="Stato elaborazione"/>
                        </Column>
                        <Column id="importDetailColDocCreato" width="14rem">
                            <Text text="Documento creato"/>
                        </Column>
                        <Column id="importDetailColLog" width="8rem" hAlign="Center">
                            <Text text="Registro"/>
                        </Column>
                    </columns>
                    <items>
                        <ColumnListItem type="Inactive" highlight="{detail>RowHighlight}">
                            <cells>
                                <Text text="{detail>IdOdvTmp}"/>
                                <Text text="{detail>Posnr}"/>
                                <ObjectStatus text="{parts: [{path: 'detail>Stato'}], formatter: '.formatter.statoTextDetail'}" state="{detail>StatoState}" icon="{parts: [{path: 'detail>Stato'}], formatter: '.formatter.statoIconDetail'}"/>
                                <Text text="{detail>DocCreato}"/>
                                <Button icon="sap-icon://message-information" type="Transparent" press=".onOpenApplicationLog" visible="{= !!${detail>Messaggio} }"/>
                            </cells>
                        </ColumnListItem>
                    </items>
                </Table>
            </VBox>
        </content>
    </Page>
</mvc:View>