<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core"
    xmlns:u="sap.ui.unified">
    <Dialog id="correctionImportDialog" title="Importazione correttiva" contentWidth="92rem" contentHeight="46rem" draggable="true" resizable="true" class="iovCorrectionDialog">
        <content>
            <VBox id="correctionContent" width="100%" height="100%" class="sapUiMediumMargin">
                <HBox id="correctionFileBox" width="100%" alignItems="Center" class="iovImportBox">
                    <Input id="correctionImportNameInput" value="{detail>/CorrectionImportName}" width="40rem" editable="false"/>
                    <u:FileUploader  id="correctionFileUploader" name="correctionExcelUpload" buttonOnly="true" buttonText="Sfoglia..." sameFilenameAllowed="true" fileType="xls,xlsx" change=".onCorrectionFileUploaderChange" typeMissmatch=".onCorrectionFileTypeMissmatch" class="iovBrowseButton"/>
                </HBox>
                <MessageStrip id="correctionValidationMessageStrip" visible="{detail>/CorrectionShowValidationMessage}" text="{detail>/CorrectionValidationMessage}" type="{detail>/CorrectionValidationMessageType}" showIcon="true" class="iovValidationMessage"/>
                <VBox id="correctionDropArea" width="100%" height="100%" alignItems="Center" justifyContent="Center" visible="{= !${detail&gt;/CorrectionPreviewVisible} }" class="iovDropArea">
                    <core:Icon id="correctionDropAreaIcon" src="sap-icon://document-text" size="5rem" class="iovDropIcon"/>
                    <Text id="correctionDropAreaText" text="Seleziona o trascina un file XLSX per l'anteprima." class="iovCorrectionDropText"/>
                    <Text id="correctionDropAreaHint" text="Consiglio: durante la revisione dei dati nel file, non è necessario eliminare i record precedentemente riusciti." class="iovCorrectionDropHint"/>
                </VBox>
                <VBox id="correctionPreviewBox" visible="{detail>/CorrectionPreviewVisible}" width="100%" height="100%">
                    <OverflowToolbar id="correctionPreviewToolbar">
                        <Title id="correctionPreviewTitle" text="Anteprima importazione correttiva" level="H3"/>
                    </OverflowToolbar>
                    <Table id="correctionPreviewTable" width="100%" fixedLayout="false" growing="true" growingThreshold="50" items="{detail>/CorrectionPreviewRows}">
                        <columns>
                            <Column id="correctionColTemporarySalesOrderId" width="14rem">
                                <Text text="ID (odv temporaneo)*"/>
                            </Column>
                            <Column id="correctionColNoteType" width="9rem">
                                <Text text="Tipo nota*"/>
                            </Column>
                            <Column id="correctionColShipToParty" width="12rem">
                                <Text text="Destinatario merci*"/>
                            </Column>
                            <Column id="correctionColSoldToParty" width="10rem">
                                <Text text="Committente*"/>
                            </Column>
                            <Column id="correctionColReason" width="8rem">
                                <Text text="Causale*"/>
                            </Column>
                            <Column id="correctionColCurrency" width="8rem">
                                <Text text="Valuta*"/>
                            </Column>
                        </columns>
                        <items>
                            <ColumnListItem id="correctionPreviewItem" highlight="{detail>RowHighlight}">
                                <cells>
                                    <Text id="correctionCellTemporarySalesOrderId" text="{detail>TemporarySalesOrderId}"/>
                                    <Text id="correctionCellNoteType" text="{detail>NoteType}"/>
                                    <Text id="correctionCellShipToParty" text="{detail>ShipToParty}"/>
                                    <Text id="correctionCellSoldToParty" text="{detail>SoldToParty}"/>
                                    <Text id="correctionCellReason" text="{detail>Reason}"/>
                                    <Text id="correctionCellCurrency" text="{detail>Currency}"/>
                                </cells>
                            </ColumnListItem>
                        </items>
                    </Table>
                </VBox>
            </VBox>
        </content>
        <beginButton>
            <Button id="correctionImportButton" text="Importa" type="Emphasized" enabled="{detail>/CorrectionCanImport}" press=".onCorrectionImport"/>
        </beginButton>
        <endButton>
            <Button id="correctionCloseButton" text="Chiudi" type="Transparent" press=".onCloseCorrectionImportDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>