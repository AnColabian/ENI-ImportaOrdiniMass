<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog id="applicationLogDialog" title="Registro elaborazione" contentWidth="60rem" draggable="true" resizable="true">
        <content>
            <Table id="applicationLogTable" width="100%" fixedLayout="false" items="{detail>/SelectedLogMessages}">
                <columns>
                    <Column id="applicationLogColSeverity" width="12rem">
                        <Text text="Stato"/>
                    </Column>
                    <Column id="applicationLogColDescription">
                        <Text text="Messaggio"/>
                    </Column>
                    <Column id="applicationLogColTimestamp" width="14rem">
                        <Text text="Data prestazione"/>
                    </Column>
                </columns>
                <items>
                    <ColumnListItem id="applicationLogItem">
                        <cells>
                            <ObjectStatus
                                text="{detail>Severity}"
                                state="{detail>SeverityState}"
                                icon="{parts: [{path: 'detail>Severity'}], formatter: '.formatter.statoIconDetail'}"/>
                            <Text text="{detail>Description}"/>
                            <Text text="{detail>Timestamp}"/>
                        </cells>
                    </ColumnListItem>
                </items>
            </Table>
        </content>
        <endButton>
            <Button id="applicationLogCloseButton" text="Chiudi" type="Transparent" press=".onCloseApplicationLogDialog"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>