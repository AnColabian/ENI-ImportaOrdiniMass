<core:FragmentDefinition xmlns="sap.m"
    xmlns:core="sap.ui.core">
    <Dialog id="columnSettingsDialog" title="Definisci proprietà colonna" contentWidth="70rem" contentHeight="46rem" draggable="true" resizable="true" class="iovColumnSettingsDialog">
        <subHeader>
            <Toolbar id="columnSettingsToolbar">
                <ToolbarSpacer id="columnSettingsToolbarSpacerLeft"/>
                <SearchField id="columnSettingsSearchField" width="25rem" placeholder="Cerca" liveChange=".onColumnSettingsSearch" search=".onColumnSettingsSearch"/>
                <Button id="columnSettingsShowSelectionButton" text="Visualizza selezione" type="Transparent"/>
                <Button id="columnSettingsMoveFirstButton" icon="sap-icon://collapse-group" type="Transparent" enabled="false"/>
                <Button id="columnSettingsMoveUpButton" icon="sap-icon://navigation-up-arrow" type="Transparent" enabled="false"/>
                <Button id="columnSettingsMoveDownButton" icon="sap-icon://navigation-down-arrow" type="Transparent" enabled="false"/>
                <Button id="columnSettingsMoveLastButton" icon="sap-icon://expand-group" type="Transparent" enabled="false"/>
            </Toolbar>
        </subHeader>
        <content>
            <VBox id="columnSettingsContent" width="100%" height="100%">
                <HBox id="columnSettingsSelectAllBox" width="100%" alignItems="Center" class="iovColumnSettingsSelectAllBox">
                    <CheckBox id="selectAllColumnsCheckBox" selected="{view>/allColumnsSelected}" select=".onColumnSettingsToggleAll"/>
                    <Text id="selectAllColumnsText" text="{= 'Seleziona tutto (' + ${view&gt;/selectedColumnCount} + '/' + ${view&gt;/columnSettingsCount} + ')' }" class="iovColumnSettingsSelectAllText"/>
                </HBox>
                <List id="columnSettingsList" width="100%" mode="None" showSeparators="Inner" items="{view>/columnSettingsDraft}" class="iovColumnSettingsList">
                    <items>
                        <CustomListItem id="columnSettingsListItem">
                            <HBox id="columnSettingsListItemBox" width="100%" alignItems="Center" class="iovColumnSettingsListItemBox">
                                <CheckBox id="columnSettingsListItemCheckBox" selected="{view>visible}" select=".onColumnSettingsItemSelect"/>
                                <Text id="columnSettingsListItemText" text="{view>label}" class="iovColumnSettingsListItemText"/>
                            </HBox>
                        </CustomListItem>
                    </items>
                </List>
            </VBox>
        </content>
        <beginButton>
            <Button id="columnSettingsConfirmButton" text="OK" type="Emphasized" press=".onColumnSettingsConfirm"/>
        </beginButton>
        <endButton>
            <Button id="columnSettingsCancelButton" text="Annulla" type="Transparent" press=".onColumnSettingsCancel"/>
        </endButton>
    </Dialog>
</core:FragmentDefinition>